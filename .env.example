PORT=3000
HOST=0.0.0.0
NODE_ENV=development

DATABASE_URL="file:./data/paymatubyte.db"

# Bold — mismo formato que fymapp-api (.env)
URL_API_BOLD=https://integrations.api.bold.co/online/link/v1
AUTHORIZATION_BOLD="x-api-key TU_LLAVE_PRODUCCION"
AUTHORIZATION_BOLD_DEV="x-api-key TU_LLAVE_PRUEBAS"

# Opcional: conversión USD→COP (catálogo con currency USD + convertUsdToCop en app)
URL_API_EXCHANGERATE=https://v6.exchangerate-api.com/v6/TU_KEY/latest/USD
BOLD_DEFAULT_IMAGE_URL=https://robohash.org/matubyte.png

PAYMATUBYTE_PUBLIC_URL=http://localhost:3000
# Producción (servidor): https://pay.matubyte.com — ver deploy/DEPLOY.md
# Bold rechaza callback http://localhost (403). Local rápido: solo tarjeta sin retorno automático:
# BOLD_DEV_NO_CALLBACK=true
# Flujo completo (PSE + vuelta al dashboard): ngrok http 3000 → PAYMATUBYTE_PUBLIC_URL=https://xxxx.ngrok-free.app

BOLD_WEBHOOK_SECRET=
PAYMATUBYTE_MASTER_KEY=
DEMO_PAGE_ENABLED=true
DEMO_APP_ID=paymatubyte
