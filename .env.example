PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# MatuDB — https://db.matudb.com (proyecto dedicado PayMatuByte)
MATUDB_URL=https://db.matudb.com
MATUDB_PROJECT_ID=52ef1dbd-e783-4828-9298-0d2445297f5d
MATUDB_API_KEY=mb_6ca5b5a0044b9e3ca1dc4f9d953f89ff790457048ce172defad35caa69458c48


URL_API_BOLD=https://integrations.api.bold.co/online/link/v1
AUTHORIZATION_BOLD="x-api-key TU_LLAVE_PRODUCCION"
AUTHORIZATION_BOLD_DEV="x-api-key TU_LLAVE_PRUEBAS"

# Opcional: si falla o no existe, se usa EXCHANGE_RATE_COP_PER_USD (Matu AI USD→COP)
URL_API_EXCHANGERATE=https://v6.exchangerate-api.com/v6/TU_KEY/latest/USD
EXCHANGE_RATE_COP_PER_USD=4200
BOLD_DEFAULT_IMAGE_URL=https://robohash.org/matubyte.png
PAYMATUBYTE_PUBLIC_URL=http://localhost:3000
# HTTPS de PayMatuByte desplegado (misma MatuDB) — solo si PAYMATUBYTE_PUBLIC_URL no es HTTPS
PAYMATUBYTE_CALLBACK_FALLBACK_URL=https://pay.matubyte.com
# Sin HTTPS local: true = solo tarjeta, sin callback Bold. Para retorno automático usa ngrok:
#   ngrok http 3000
#   PAYMATUBYTE_PUBLIC_URL=https://TU-ID.ngrok-free.app
# BOLD_DEV_NO_CALLBACK=true

BOLD_WEBHOOK_SECRET=
PAYMATUBYTE_MASTER_KEY=
DEMO_PAGE_ENABLED=true
DEMO_APP_ID=paymatubyte

# Push MatuPay (Firebase → Cuenta de servicio → JSON o variables)
